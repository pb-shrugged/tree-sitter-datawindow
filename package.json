{
  "name": "@pb-shrugged/tree-sitter-datawindow",
  "version": "0.0.4",
  "description": "Datawindow syntax grammar for Tree-sitter",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pb-shrugged/tree-sitter-datawindow.git"
  },
  "license": "MIT",
  "author": {
    "name": "Jose Cagnini",
    "email": "jose.cagnini@proton.me"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "datawindow"
  ],
  "files": [
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "*.wasm",
    "grammars/datawindow_expression/grammar.js",
    "grammars/datawindow_expression/package.json",
    "grammars/datawindow_expression/src/**",
    "grammars/datawindow_syntax/grammar.js",
    "grammars/datawindow_syntax/package.json",
    "grammars/datawindow_syntax/src/**"
  ],
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "^0.26.7",
    "eslint": "^9.35.0",
    "eslint-config-treesitter": "^1.0.2"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "test": "node --test bindings/node/*_test.js"
  }
}
