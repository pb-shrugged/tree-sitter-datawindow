{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "datawindow_expression",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "STRING",
      "value": "hello"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9\\-_$#%]*"
    },
    "_literal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "integer_literal"
        },
        {
          "type": "SYMBOL",
          "name": "decimal_literal"
        },
        {
          "type": "SYMBOL",
          "name": "real_literal"
        },
        {
          "type": "SYMBOL",
          "name": "string_literal"
        },
        {
          "type": "SYMBOL",
          "name": "date_literal"
        },
        {
          "type": "SYMBOL",
          "name": "time_literal"
        },
        {
          "type": "SYMBOL",
          "name": "boolean_literal"
        }
      ]
    },
    "integer_literal": {
      "type": "PATTERN",
      "value": "\\d+"
    },
    "decimal_literal": {
      "type": "PATTERN",
      "value": "\\d*\\.\\d+"
    },
    "real_literal": {
      "type": "PATTERN",
      "value": "(?:[0-9]+(?:\\.[0-9]*)?|\\.[0-9]+)[Ee][+-]?[0-9]+"
    },
    "date_literal": {
      "type": "PATTERN",
      "value": "(?:\\d{4}-\\d{2}-\\d{2})"
    },
    "time_literal": {
      "type": "PATTERN",
      "value": "(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,6})?"
    },
    "string_literal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "double_quote"
            },
            {
              "type": "ALIAS",
              "content": {
                "type": "REPEAT",
                "content": {
                  "type": "IMMEDIATE_TOKEN",
                  "content": {
                    "type": "PREC",
                    "value": 1,
                    "content": {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "PATTERN",
                          "value": "[^\"\\\\]"
                        },
                        {
                          "type": "PATTERN",
                          "value": "\\\\."
                        },
                        {
                          "type": "PATTERN",
                          "value": "~\""
                        }
                      ]
                    }
                  }
                }
              },
              "named": true,
              "value": "string_content"
            },
            {
              "type": "SYMBOL",
              "name": "double_quote"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "single_quote"
            },
            {
              "type": "ALIAS",
              "content": {
                "type": "REPEAT",
                "content": {
                  "type": "IMMEDIATE_TOKEN",
                  "content": {
                    "type": "PREC",
                    "value": 1,
                    "content": {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "PATTERN",
                          "value": "[^'\\\\]"
                        },
                        {
                          "type": "PATTERN",
                          "value": "\\\\."
                        },
                        {
                          "type": "PATTERN",
                          "value": "~'"
                        }
                      ]
                    }
                  }
                }
              },
              "named": true,
              "value": "string_content"
            },
            {
              "type": "SYMBOL",
              "name": "single_quote"
            }
          ]
        }
      ]
    },
    "boolean_literal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "PATTERN",
            "value": "[tT][rR][uU][eE]"
          },
          "named": false,
          "value": "true"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "PATTERN",
            "value": "[fF][aA][lL][sS][eE]"
          },
          "named": false,
          "value": "false"
        }
      ]
    },
    "line_comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "//"
        },
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "PREC",
            "value": 1,
            "content": {
              "type": "PATTERN",
              "value": ".*"
            }
          }
        }
      ]
    },
    "block_comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "/*"
          },
          {
            "type": "PATTERN",
            "value": "[^*]*\\*+([^/*][^*]*\\*+)*"
          },
          {
            "type": "STRING",
            "value": "/"
          }
        ]
      }
    },
    "open_parenthesis": {
      "type": "STRING",
      "value": "("
    },
    "close_parenthesis": {
      "type": "STRING",
      "value": ")"
    },
    "single_quote": {
      "type": "STRING",
      "value": "'"
    },
    "double_quote": {
      "type": "STRING",
      "value": "\""
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "line_comment"
    },
    {
      "type": "SYMBOL",
      "name": "block_comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}