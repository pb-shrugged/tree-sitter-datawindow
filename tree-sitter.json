{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "datawindow_syntax",
      "camelcase": "DatawindowSyntax",
      "title": "Datawindow",
      "scope": "source.datawindow",
      "path": "grammars/datawindow_syntax",
      "file-types": [
        "srd"
      ],
      "injection-regex": "^datawindow$",
      "class-name": "TreeSitterDatawindowSyntax"
    },
    {
      "name": "datawindow_expression",
      "camelcase": "DatawindowExpression",
      "title": "DatawindowExpression",
      "scope": "source.datawindow_expression",
      "path": "grammars/datawindow_expression",
      "file-types": null,
      "injection-regex": "^datawindowexpression$",
      "class-name": "TreeSitterDatawindowExpression"
    }
  ],
  "metadata": {
    "version": "0.0.3",
    "license": "MIT",
    "description": "Datawindow syntax grammar for Tree-sitter",
    "authors": [
      {
        "name": "Jose Cagnini",
        "email": "jose.cagnini@proton.me"
      }
    ],
    "links": {
      "repository": "https://github.com/pb-shrugged/tree-sitter-datawindow"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}