  "grammars": [
    {
      "name": "datawindow",
      "camelcase": "Datawindow",
      "title": "Datawindow",
      "scope": "source.datawindow",
      "file-types": [
        "srd"
      ],
      "injection-regex": "^datawindow$",
      "class-name": "TreeSitterDatawindow"
    }
